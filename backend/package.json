{
  "name": "quiz-platform-backend",
  "version": "1.0.0",
  "description": "Express data API for the quiz training platform",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "dev": "npx kill-port 5001 && nodemon server.js",
    "seed": "node seed/seed.js",
    "sync:ktmt:dry": "node seed/syncKtmtFromRepo.js --dry-run",
    "sync:ktmt": "node seed/syncKtmtFromRepo.js",
    "sync:monhoc:dry": "node seed/syncMonhocFromRepo.js --dry-run",
    "sync:monhoc": "node seed/syncMonhocFromRepo.js",
    "sync:ktct:dry": "node seed/syncKtctFromRepo.js --dry-run",
    "sync:ktct": "node seed/syncKtctFromRepo.js",
    "sync:vatly:dry": "node seed/syncVatLyFromRepo.js --dry-run",
    "sync:vatly": "node seed/syncVatLyFromRepo.js",
    "migrate:hierarchy:dry": "node seed/migrateHierarchy.js --dry-run",
    "migrate:hierarchy": "node seed/migrateHierarchy.js",
    "migrate:subject-icons:dry": "node seed/migrateSubjectIcons.js --dry-run",
    "migrate:subject-icons": "node seed/migrateSubjectIcons.js",
    "import:monhoc:dry": "node seed/importMonhocSubjects.js --dry-run",
    "import:monhoc": "node seed/importMonhocSubjects.js",
    "align:monhoc:business": "node seed/alignBusinessSubjects.js",
    "import:monhoc:questions:dry": "node seed/importMonhocQuestionsFromPdf.js --dry-run",
    "import:monhoc:questions": "node seed/importMonhocQuestionsFromPdf.js",
    "import:vatly:html:dry": "node seed/importVatLyFromHtml.js --dry-run",
    "import:vatly:html": "node seed/importVatLyFromHtml.js",
    "extract:tmdt:answers": "python seed/extractTmdtAnswersFromImages.py",
    "apply:tmdt:answers:dry": "node seed/applyTmdtAnswerKey.js --dry-run",
    "apply:tmdt:answers": "node seed/applyTmdtAnswerKey.js",
    "apply:pldc:answers:dry": "node seed/applyPldcAnswerKeyFromTxt.js --dry-run",
    "apply:pldc:answers": "node seed/applyPldcAnswerKeyFromTxt.js",
    "extract:answers:pldc": "python seed/extractAnswersFromImages.py --image-dir ../monhoc/_pldc_zip --output seed/answer_key_pldc.json --subject PLDC",
    "extract:answers:qth": "python seed/extractAnswersFromImages.py --image-dir ../monhoc/_qth_zip --output seed/answer_key_qth.json --subject QTH",
    "extract:answers:tmdt": "python seed/extractAnswersFromImages.py --image-dir ../monhoc/_tmdt_zip --output seed/answer_key_tmdt.json --subject TMDT",
    "apply:answers:pldc:dry": "node seed/applyAnswerKey.js --subject PLDC --key seed/answer_key_pldc.json --dry-run",
    "apply:answers:qth:dry": "node seed/applyAnswerKey.js --subject QTH --key seed/answer_key_qth.json --dry-run",
    "apply:answers:tmdt:dry": "node seed/applyAnswerKey.js --subject TMDT --key seed/answer_key_tmdt.json --dry-run",
    "apply:answers:pldc": "node seed/applyAnswerKey.js --subject PLDC --key seed/answer_key_pldc.json",
    "apply:answers:qth": "node seed/applyAnswerKey.js --subject QTH --key seed/answer_key_qth.json",
    "apply:answers:tmdt": "node seed/applyAnswerKey.js --subject TMDT --key seed/answer_key_tmdt.json",
    "test:regression:api": "node seed/regressionApiTest.js"
  },
  "dependencies": {
    "bcryptjs": "^2.4.3",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.18.3",
    "express-rate-limit": "^7.5.0",
    "helmet": "^8.1.0",
    "jsonwebtoken": "^9.0.1",
    "mongoose": "^7.4.0",
    "morgan": "^1.10.0",
    "pdf-parse": "^1.1.1",
    "pdfjs-dist": "^5.5.207",
    "ws": "^8.19.0"
  },
  "devDependencies": {
    "nodemon": "^3.0.1"
  }
}
