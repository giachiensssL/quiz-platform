{
  "name": "quiz-platform-backend",
  "version": "1.0.0",
  "description": "Express data API for the quiz training platform",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "dev": "npx kill-port 5001 && nodemon server.js",
    "seed": "node seed/seed.js",
    "migrate:hierarchy:dry": "node seed/migrateHierarchy.js --dry-run",
    "migrate:hierarchy": "node seed/migrateHierarchy.js",
